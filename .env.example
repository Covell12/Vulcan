# Copy to .env and fill in as milestones require. Never commit .env.

# Intent parser (Milestone 3): pick a provider with VISION_PROVIDER, then set
# only that provider's key. Switching providers is one edit to VISION_PROVIDER
# + a server restart -- no code changes.
VISION_PROVIDER=openai        # "openai" (default) or "anthropic"
VISION_MODEL=                 # optional: override the default model for the selected provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=              # required if VISION_PROVIDER=anthropic

REPLICATE_API_TOKEN=          # needed from Milestone 4 (depth prior), if using Replicate
STRIPE_SECRET_KEY=            # needed from Milestone 6
STRIPE_WEBHOOK_SECRET=        # needed from Milestone 6
VULCAN_ENV=dev
