# Copy to .env and fill in as milestones require. Never commit .env.
#
# NOTE: keep comments on their OWN lines, never inline after a value —
# python-dotenv parses `KEY=   # comment` with the comment AS the value, which
# would make an "empty" key look set and defeat the startup fail-fast checks.

# --- Intent parser (Milestone 3) -------------------------------------------
# Pick a provider with VISION_PROVIDER, then set only that provider's key.
# Switching providers is one edit to VISION_PROVIDER + a server restart.
# VISION_PROVIDER: "openai" (default) or "anthropic"
VISION_PROVIDER=openai
# VISION_MODEL: optional, overrides the default model for the selected provider
VISION_MODEL=
# OPENAI_API_KEY: required if VISION_PROVIDER=openai
OPENAI_API_KEY=
# ANTHROPIC_API_KEY: required if VISION_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# --- Depth prior (Milestone 4), optional -----------------------------------
# DEPTH_PROVIDER=none (default) runs the whole product with no depth model.
# DEPTH_PROVIDER=replicate adds metric-scale suggestions + the unit-mistake
# cross-check, and needs REPLICATE_API_TOKEN. One edit to switch.
# DEPTH_PROVIDER: "none" (default) or "replicate"
DEPTH_PROVIDER=none
# DEPTH_MODEL: optional, Replicate model id returning metric depth + focal length
DEPTH_MODEL=
# REPLICATE_API_TOKEN: required if DEPTH_PROVIDER=replicate
REPLICATE_API_TOKEN=

# --- Freeform generation (Track B), optional -------------------------------
# Used only when a request fits no template and the user opts into a custom
# design. Same seam pattern as the vision parser; reuses the same API keys.
# CODEGEN_PROVIDER: "openai" (default) or "anthropic"
CODEGEN_PROVIDER=openai
# CODEGEN_MODEL: optional, overrides the default model for the selected provider
CODEGEN_MODEL=
# VULCAN_REVIEW_TOKEN: founder secret for approving/rejecting freeform designs.
# When set, POST /review/{id} requires a matching X-Review-Token header. Leave
# empty ONLY for local dev — it MUST be set before the API is reachable beyond
# localhost, or anyone could self-approve their own generated design.
# SECURITY: freeform generation runs LLM-authored code. The AST verifier +
# process isolation harden it, but they are NOT an OS jail — do not expose
# freeform beyond localhost without a real sandbox (seccomp/gVisor/container).
VULCAN_REVIEW_TOKEN=

# --- Later milestones ------------------------------------------------------
# Needed from Milestone 6:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

VULCAN_ENV=dev
